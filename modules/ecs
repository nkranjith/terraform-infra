# 1. Spin up the GitHub/Registry ECS Module
module "ecs" {
  source  = "terraform-aws-modules/ecs/aws"
  version = "~> 5.0"

  cluster_name = "production-ecs-cluster"

  # Allocate capacity providers (Fargate is fully serverless)
  fargate_capacity_providers = {
    FARGATE = {
      default_capacity_provider_strategy = {
        weight = 100
      }
    }
  }

  tags = {
    Environment = "prod"
  }
}

# 2. Set up an Application Load Balancer to accept web traffic
module "alb" {
  source  = "terraform-aws-modules/alb/aws"
  version = "~> 9.0"

  name    = "ecs-app-alb"
  vpc_id  = module.vpc.vpc_id
  subnets = module.vpc.public_subnets # Public subnets for entry point

  # Security Group rules allowing external web traffic
  security_group_ingress_rules = {
    all_http = {
      from_port   = 80
      to_port     = 80
      protocol    = "tcp"
      cidr_blocks = ["0.0.0.0/0"]
    }
  }

  # Forward incoming traffic on port 80 to the ECS Target Group
  listeners = {
    http = {
      port     = 80
      protocol = "HTTP"
      forward = {
        target_group_key = "ecs-tasks"
      }
    }
  }

  target_groups = {
    ecs-tasks = {
      backend_protocol                  = "HTTP"
      backend_port                      = 80
      target_type                       = "ip" # Required for Fargate
      deregistration_delay              = 10
      load_balancing_algorithm_type     = "round_robin"
      
      health_check = {
        path                = "/"
        port                = "80"
        protocol            = "HTTP"
        healthy_threshold   = 3
        unhealthy_threshold = 3
        interval            = 30
        timeout             = 5
      }
    }
  }
}

# 3. Create the ECS Service & Task Definition
module "ecs_service" {
  source  = "terraform-aws-modules/ecs/aws//modules/service"
  version = "~> 5.0"

  name        = "web-application-service"
  cluster_arn = module.ecs.cluster_arn

  cpu    = 256 # 0.25 vCPU
  memory = 512 # 512 MB

  # Deploy your workload into the private subnets for security
  subnet_ids = module.vpc.private_subnets
  
  # Connect the ECS service to the Load Balancer
  load_balancer = {
    service = {
      target_group_arn = module.alb.target_groups["ecs-tasks"].arn
      container_name   = "app-container"
      container_port   = 80
    }
  }

  # Container Definition Blueprint
  container_definitions = {
    app-container = {
      cpu       = 256
      memory    = 512
      essential = true
      image     = "nginx:alpine" # Pull public image from DockerHub
      
      port_mappings = [
        {
          name          = "app-container"
          container_port = 80
          host_port      = 80
          protocol       = "tcp"
        }
      ]
    }
  }

  # Open the task's security group to receive traffic from the ALB
  security_group_rules = {
    alb_ingress_3000 = {
      type                     = "ingress"
      from_port                = 80
      to_port                  = 80
      protocol                 = "tcp"
      description              = "Allow traffic from ALB"
      source_security_group_id = module.alb.security_group_id
    }
    egress_all = {
      type        = "egress"
      from_port   = 0
      to_port     = 0
      protocol    = "-1"
      cidr_blocks = ["0.0.0.0/0"]
    }
  }
}

# 4. Dynamic URL Output
output "application_url" {
  description = "Navigate to this URL to see your running container"
  value       = "http://${module.alb.dns_name}"
}

