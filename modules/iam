# 1. Fetch the current AWS Account ID dynamically
data "aws_caller_identity" "current" {}

# 2. Build the Task Execution Role (Used by the AWS ECS Agent to bootstrap the container)
module "ecs_task_execution_role" {
  source  = "terraform-aws-modules/iam/aws//modules/iam-assumable-role"
  version = "~> 5.0"

  create_role       = true
  role_name         = "production-ecs-execution-role"
  role_description  = "Managed by Terraform: Allows ECS agent to pull ECR images and send logs"
  
  # Allow the Amazon ECS service to assume this identity
  trusted_role_services = ["://amazonaws.com"]

  # Attach AWS managed policy for basic execution capabilities
  custom_role_policy_arns = [
    "arn:aws:iam::aws:policy/service-role/AmazonECSTaskExecutionRolePolicy"
  ]
}

# 3. Create a custom inline policy for secure parameter fetching
resource "aws_iam_policy" "ecs_execution_secrets" {
  name        = "production-ecs-secrets-policy"
  description = "Allows ECS agent to read environment variables from Secrets Manager"

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = [
          "secretsmanager:GetSecretValue",
          "ssm:GetParameters"
        ]
        Resource = [
          "arn:aws:secretsmanager:*:*:secret:production/*",
          "arn:aws:ssm:*:*:parameter/production/*"
        ]
      }
    ]
  })
}

# Attach the custom secrets policy to the execution role
resource "aws_iam_role_policy_attachment" "execution_secrets" {
  role       = module.ecs_task_execution_role.iam_role_name
  policy_arn = aws_iam_policy.ecs_execution_secrets.arn
}

# 4. Build the Task Role (Used by your application code running inside the container)
module "ecs_task_role" {
  source  = "terraform-aws-modules/iam/aws//modules/iam-assumable-role"
  version = "~> 5.0"

  create_role       = true
  role_name         = "production-ecs-application-task-role"
  role_description  = "Managed by Terraform: Permissions utilized directly by the app code"
  
  trusted_role_services = ["://amazonaws.com"]
}

# Custom policy for application code (e.g., uploading files to a specific S3 bucket)
resource "aws_iam_policy" "app_s3_access" {
  name        = "production-app-s3-access-policy"
  description = "Allows application code to read/write to production storage assets"

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect = "Allow"
        Action = [
          "s3:GetObject",
          "s3:PutObject",
          "s3:ListBucket"
        ]
        Resource = [
          "arn:aws:s3:::production-app-assets-bucket",
          "arn:aws:s3:::production-app-assets-bucket/*"
        ]
      }
    ]
  })
}

# Attach the custom application permissions to the task role
resource "aws_iam_role_policy_attachment" "app_s3" {
  role       = module.ecs_task_role.iam_role_name
  policy_arn = aws_iam_policy.app_s3_access.arn
}

# Outputs for stitching into your ecs.tf file
output "ecs_execution_role_arn" {
  description = "Supply this to the execution_role_arn parameter in the ECS module"
  value       = module.ecs_task_execution_role.iam_role_arn
}

output "ecs_task_role_arn" {
  description = "Supply this to the task_role_arn parameter in the ECS module"
  value       = module.ecs_task_role.iam_role_arn
}
