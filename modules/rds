# 1. Create a specialized security group for the RDS Database
module "rds_security_group" {
  source  = "terraform-aws-modules/security-group/aws"
  version = "~> 5.0"

  name        = "production-rds-sg"
  description = "Access control for RDS PostgreSQL instance"
  vpc_id      = module.vpc.vpc_id

  # Open port 5432 (PostgreSQL) strictly to your ECS Service tasks
  ingress_with_source_security_group_id = [
    {
      from_port                = 5432
      to_port                  = 5432
      protocol                 = "tcp"
      description              = "Allow traffic from ECS Tasks"
      source_security_group_id = module.ecs_service.security_group_id
    }
  ]
}

# 2. Spin up the GitHub/Registry RDS Instance Module
module "rds" {
  source  = "terraform-aws-modules/rds/aws"
  version = "~> 6.0"

  identifier = "production-database"

  # Engine Details
  engine               = "postgres"
  engine_version       = "15.4"
  family               = "postgres15" # DB parameter group family
  major_engine_version = "15"
  instance_class       = "db.t4g.medium" # Cost-effective AWS Graviton instance

  # Storage Configuration
  allocated_storage     = 20
  max_allocated_storage = 100 # Allows autoscaling to prevent out-of-disk crashes

  # Database Credentials (Managed securely inside AWS Secrets Manager or variables)
  db_name  = "production_app_db"
  username = "db_admin_user"
  port     = 5432

  # Production Multi-AZ High Availability
  multi_az = true # Deploys a hot-standby copy in a second AZ for failover protection

  # Network & Placement Strategy
  db_subnet_group_name   = module.vpc.database_subnet_group_name
  vpc_security_group_ids = [module.rds_security_group.security_group_id]
  publicly_accessible    = false # Never expose production databases to the web

  # Backup & Maintenance Safeguards
  maintenance_window      = "Mon:00:00-Mon:03:00"
  backup_window           = "03:00-06:00"
  backup_retention_period = 7 # Retain automatic snapshots for 7 days
  skip_final_snapshot     = false
  deletion_protection     = true # Prevents accidental terraform destroy commands

  tags = {
    Terraform   = "true"
    Environment = "prod"
  }
}

# Capture critical DB cluster endpoints
output "rds_endpoint" {
  description = "The connection endpoint for the database cluster"
  value       = module.rds.db_instance_endpoint
}

output "rds_database_name" {
  description = "The target database name"
  value       = module.rds.db_instance_name
}

